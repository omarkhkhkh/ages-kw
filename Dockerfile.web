# ══════════════════════════════════════════════════════════
#  واجهة الموقع (React + Vite) مُقدَّمة عبر nginx — منفذ 80
#  البناء من جذر المستودع:  docker build -f Dockerfile.web -t ages-web .
# ══════════════════════════════════════════════════════════

# ── مرحلة البناء ──
# node:22-slim (Debian/glibc) وليس alpine — تفاديًا لخلل اكتشاف musl في pnpm
# الذي يمنع تنزيل الحزم الأصلية (native) لـ rollup/lightningcss
FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
# تثبيت كامل (بدون فلترة) — الفلترة تُسقط ربط الـ peer dependencies
# لحزم الـ workspace (react داخل object-storage-web)
RUN pnpm install --no-frozen-lockfile
RUN cd artifacts/tender-manager && pnpm exec vite build

# ── مرحلة التقديم ──
FROM nginx:alpine
COPY --from=build /app/artifacts/tender-manager/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
